# ---- AI provider (OpenRouter-compatible) ----
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the AI endpoint / model (defaults shown).
# Any OpenAI-compatible endpoint works. Per-project overrides are also
# configurable in the app's Settings dialog (Project.settings).
AI_ENDPOINT=https://openrouter.ai/api/v1
AI_MODEL=deepseek/deepseek-v4-flash

# ---- Database ----
# Default is a local SQLite file. Async SQLAlchemy URL.
DATABASE_URL=sqlite+aiosqlite:///./worldbuilder.db
